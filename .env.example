# Database Configuration
# PostgreSQL with PGVector extension
DATABASE_URL=postgresql://username:password@localhost:5432/postgres

# Point to OpenAI or local Ollama instance (ensure it's running)
# OpenAI default: https://api.openai.com/v1
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=your-api-key
LLM_MODEL=phi4-mini:latest

# Configure Embedding (Note: nomic-embed-text is 768 dimensions)
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_DIMENSIONS=768
# EMBEDDING_BACKEND=local

# Development Settings
LOG_LEVEL=INFO
DEBUG_MODE=false
